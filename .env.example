# Copy this file to .env and fill in the keys you need.
# .env is gitignored — your keys will never be committed.
#
# Only set the keys for the providers you actually use.
# The defaults in config/default.yaml use Groq (STT) + Gemini (LLM) + edge-tts (TTS, free).

# ---------------------------------------------------------------------------
# STT — Speech-to-Text
# ---------------------------------------------------------------------------

# Groq Whisper (default STT) — free tier available
# Get a key: https://console.groq.com
GROQ_API_KEY=

# ---------------------------------------------------------------------------
# LLM — Language Model (via LiteLLM)
# Set the key that matches the model string in config/default.yaml
# ---------------------------------------------------------------------------

# Google Gemini  (default: gemini/gemini-1.5-flash) — free tier available
# Get a key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# OpenAI  (e.g. model: openai/gpt-4o)
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq LLM  (e.g. model: groq/llama3-70b-8192) — same key as Groq STT above
# GROQ_API_KEY is already set above; no extra entry needed.

# Anthropic  (e.g. model: anthropic/claude-3-5-haiku-20241022)
# Get a key: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# TTS — Text-to-Speech
# edge-tts (default) is free and requires no key.
# piper is local and requires no key.
# ---------------------------------------------------------------------------
