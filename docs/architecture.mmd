flowchart TB
    subgraph Clients["Client Layer"]
        WEB["Web Browser<br/>─<br/>React + Vite"]
        CLI["CLI<br/>─<br/>Typer"]
    end

    subgraph Transport["API & Transport Layer"]
        REST["REST API<br/>─<br/>FastAPI + uvicorn"]
    end

    subgraph Voice["Voice Pipeline"]
        AUDIO["Audio I/O<br/>─<br/>sounddevice"]
        VAD["Voice Activity Detection<br/>─<br/>silero-vad"]
        STT["STT Adapter<br/>─<br/>Python ABC"]
        TTS["TTS Adapter<br/>─<br/>Python ABC"]
    end

    subgraph STTProviders["STT Providers"]
        GROQW["Groq Whisper — default<br/>─<br/>groq"]
        WHISPERL["Whisper Local — fallback<br/>─<br/>openai-whisper"]
    end

    subgraph TTSProviders["TTS Providers"]
        EDGETTS["Edge TTS — default<br/>─<br/>edge-tts"]
        PIPER["Piper Local — fallback<br/>─<br/>piper-tts"]
    end

    subgraph Engine["Interview Engine"]
        IE["InterviewEngine<br/>─<br/>async Python class"]
        VL["VoiceLoop<br/>─<br/>VAD + STT + TTS orchestration"]
        PROBE["Answer Probe<br/>─<br/>LLM decides: follow_up | satisfied | skip"]
        CLARIFY["Clarification Handler<br/>─<br/>LLM detects + answers clarifications"]
        PERSONA["Persona<br/>─<br/>friendly | neutral | adversarial"]
    end

    subgraph Planner["Interview Planner"]
        PA["PlannerAgent<br/>─<br/>2-step LLM: analyse + generate"]
        INGEST["Document Ingestion<br/>─<br/>pypdf / txt / md"]
        PLAN["InterviewPlan<br/>─<br/>YAML-serializable"]
    end

    subgraph LLM["LLM Adapter Layer"]
        LLMIF["LLMAdapter ABC<br/>─<br/>auto-registry via __init_subclass__"]
        LITELLM["LiteLLMAdapter<br/>─<br/>litellm — 100+ providers"]
    end

    subgraph LLMProviders["LLM Providers (via LiteLLM)"]
        GROQ["Groq — default<br/>─<br/>llama models"]
        GEMINI["Gemini Flash<br/>─<br/>google-generativeai"]
        OPENAI["OpenAI<br/>─<br/>openai"]
        ANTHROPIC["Anthropic<br/>─<br/>claude models"]
        CEREBRAS["Cerebras<br/>─<br/>cerebras-cloud-sdk"]
    end

    subgraph Scoring["Scoring & Feedback"]
        SCORER["Scorer<br/>─<br/>per-answer STAR + relevance + clarity"]
        REPORT["ScoreReport<br/>─<br/>aggregated averages + LLM summary"]
    end

    subgraph Data["Data Layer"]
        QB["QuestionBank<br/>─<br/>PyYAML — behavioral/technical/hr/system_design"]
        SESSIONS["SessionStore<br/>─<br/>SQLAlchemy + SQLite"]
    end

    subgraph Config["Configuration Layer"]
        YAML["Master Config<br/>─<br/>PyYAML + pydantic-settings"]
        PRESETS["Interview Presets<br/>─<br/>YAML plans"]
        ENV[".env<br/>─<br/>python-dotenv"]
    end

    subgraph Observability["Observability"]
        LOGGER["Structured Logger<br/>─<br/>structlog"]
    end

    Clients --> Transport
    CLI --> Engine
    Transport --> Engine
    Transport --> Planner
    Transport --> Data

    Engine --> VL
    VL --> AUDIO --> VAD --> STT
    TTS --> AUDIO
    STT -.-> STTProviders
    TTS -.-> TTSProviders

    Engine --> PROBE
    Engine --> CLARIFY
    Engine --> PERSONA
    Engine --> LLM
    Engine --> Scoring
    Engine --> Data

    Planner --> PA --> INGEST
    PA --> LLM

    LLMIF --> LITELLM --> LLMProviders

    Scoring --> SESSIONS
    Data --> QB & SESSIONS

    Config --> Engine
    Config --> LLM
    Config --> Voice

    Engine --> LOGGER
