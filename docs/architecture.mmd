flowchart TB
    subgraph Clients["Client Layer"]
        WEB["Web Browser<br/>─<br/>React + Vite"]
        CLI["CLI<br/>─<br/>Typer"]
        SDK["Python SDK<br/>─<br/>Python package"]
    end

    subgraph Transport["API & Transport Layer"]
        REST["REST API<br/>─<br/>FastAPI"]
        WS["WebSocket Server<br/>─<br/>FastAPI WebSockets"]
    end

    subgraph Voice["Voice Pipeline"]
        AUDIO["Audio I/O Handler<br/>─<br/>sounddevice / PyAudio"]
        VAD["Voice Activity Detection<br/>─<br/>silero-vad"]
        STT["STT Adapter<br/>─<br/>Python ABC"]
        TTS["TTS Adapter<br/>─<br/>Python ABC"]
        TRANSCRIPT["Transcript Manager<br/>─<br/>asyncio + Pydantic"]
    end

    subgraph STTProviders["STT Providers"]
        GROQW["Groq Whisper — default<br/>─<br/>groq"]
        WHISPERL["Whisper Local — fallback<br/>─<br/>openai-whisper"]
        DEEPGRAM["Deepgram<br/>─<br/>deepgram-sdk"]
        ASSEMBLYAI["AssemblyAI<br/>─<br/>assemblyai"]
    end

    subgraph TTSProviders["TTS Providers"]
        EDGETTS["Edge TTS — default<br/>─<br/>edge-tts"]
        PIPER["Piper Local — fallback<br/>─<br/>piper-tts"]
        ELEVEN["ElevenLabs<br/>─<br/>elevenlabs"]
    end

    subgraph Engine["Interview Engine"]
        SM["Session State Machine<br/>─<br/>LangGraph"]
        QG["Question Selector<br/>─<br/>LangGraph node"]
        FU["Follow-up Generator<br/>─<br/>LangGraph + LLM"]
        TC["Time Controller<br/>─<br/>asyncio"]
        PM["Persona Manager<br/>─<br/>Pydantic + Jinja2"]
    end

    subgraph LLM["LLM Adapter Layer"]
        LLMIF["Provider Interface<br/>─<br/>Python ABC"]
        GROQ["Groq — default<br/>─<br/>groq"]
        GEMINI["Gemini Flash<br/>─<br/>google-generativeai"]
        OPENROUTER["OpenRouter<br/>─<br/>openai (compatible)"]
        CEREBRAS["Cerebras<br/>─<br/>cerebras-cloud-sdk"]
        MISTRAL["Mistral<br/>─<br/>mistralai"]
    end

    subgraph Scoring["Scoring & Feedback Engine"]
        SCORER["Per-answer Scorer<br/>─<br/>Instructor + Pydantic"]
        FILLER["Filler Word Detector<br/>─<br/>regex + custom Python"]
        REPORT["Session Report Generator<br/>─<br/>Instructor + Pydantic"]
        PROGRESS["Progress Tracker<br/>─<br/>SQLAlchemy"]
    end

    subgraph Data["Data Layer"]
        QB["Question Bank<br/>─<br/>PyYAML + SQLite"]
        CHROMA["Semantic Search<br/>─<br/>ChromaDB"]
        RESUME["Resume & JD Parser<br/>─<br/>pdfplumber + spaCy"]
        SESSIONS["Session Store<br/>─<br/>SQLAlchemy + SQLite"]
    end

    subgraph Config["Configuration Layer"]
        YAML["Master Config<br/>─<br/>PyYAML + pydantic-settings"]
        PRESETS["Interview Presets<br/>─<br/>PyYAML"]
        RLGUARD["Rate Limit Guard<br/>─<br/>custom Python"]
    end

    subgraph Observability["Observability Stack"]
        LOGGER["Structured Logger<br/>─<br/>structlog"]
        OTEL["Traces<br/>─<br/>opentelemetry-python"]
        PROM["Metrics<br/>─<br/>prometheus-client"]
        GRAFANA["Dashboard<br/>─<br/>Grafana"]
        REPLAY["Session Replay<br/>─<br/>SQLite + JSON"]
    end

    Clients --> Transport
    Transport --> Voice
    Transport --> Engine

    AUDIO --> VAD --> STT --> TRANSCRIPT
    TTS --> AUDIO
    STT -.-> STTProviders
    TTS -.-> TTSProviders

    TRANSCRIPT --> Engine
    Engine --> TTS

    Engine --> LLM
    Engine --> Scoring
    Engine --> Data

    LLMIF --> GROQ & GEMINI & OPENROUTER & CEREBRAS & MISTRAL

    Data --> QB & CHROMA & RESUME & SESSIONS
    Scoring --> SESSIONS

    Config --> Engine
    Config --> LLM
    Config --> Voice
    Config --> RLGUARD

    Engine --> OTEL
    LLM --> OTEL
    Voice --> OTEL
    OTEL --> PROM --> GRAFANA
    Engine --> LOGGER --> REPLAY
